# Telegram bot token from @BotFather (needed to validate Mini App requests
# and to check channel/group membership for verified tasks)
BOT_TOKEN=123456789:AAExampleTokenReplaceThisWithYourOwn

# Your bot's username (no @), used to build referral links and shown
# nowhere else.
BOT_USERNAME=your_bot_username

# Port the API server listens on
PORT=3000

# Comma separated list of origins allowed to call the API (your frontend URL)
ALLOWED_ORIGIN=https://your-frontend-domain.example

# Telegram channel/group usernames (with @) used for the "verified" join tasks.
# The bot must be an admin of these chats to be able to check membership.
REQUIRED_CHANNEL=@your_channel
REQUIRED_GROUP=@your_group

# Secret token you choose yourself and register with Telegram via
# setWebhook's `secret_token` parameter (see README). Telegram echoes it
# back on every webhook call in the x-telegram-bot-api-secret-token header,
# so this proves an incoming /telegram-webhook request really came from
# Telegram and not from a random script trying to fake a Stars payment.
WEBHOOK_SECRET=choose-a-long-random-string-here

# Set to "true" while developing locally to skip strict Telegram initData
# signature checks. NEVER set this to true in production.
DEV_SKIP_AUTH=false
